# Local development uses a local libSQL database automatically when Turso env vars are empty.
# Local DB path: ./data/cash-flow.sqlite

# Production Turso/libSQL database.
# Isi dari Turso CLI/dashboard, lalu set juga di hosting provider.
TURSO_DATABASE_URL=libsql://your-database-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
